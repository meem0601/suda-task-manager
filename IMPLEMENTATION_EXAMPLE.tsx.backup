// ============================================

// ❌ Before
<button
  onClick={onGenerateAI}
  className="text-xs px-3 py-1.5 bg-blue-600 text-white rounded-lg active:bg-blue-700"
>
  {localTask.ai_suggestion ? '再生成' : '✨ AI提案を生成'}
</button>

// ✅ After
<button
  onClick={onGenerateAI}
